{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "formatter": true,
  "permission": {
    "bash": {
      "rm *": "ask",
      "git *": "ask",
      "git status": "allow",
      "git diff *": "allow"
    },
    "read": {
      "*.env*": "deny",
      "*.env.example": "allow"
    }
  },
  "default_agent": "plan"
}
